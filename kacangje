#!/usr/bin/env bash
# kacangje - Malaysian SME AI Assistant
# One-command AI assistant for SME office work.
# Same agentic architecture as OpenCode/Claude Code, but for non-coders.
# Uses LLM to interpret prompts → execute actions → return results.
#
# Built from Mesolitica GRPO models: https://huggingface.co/mesolitica
# Architecture: user prompt → AI interprets → runs tool/action → returns result

set -euo pipefail

VERSION="2.1.0"
BLUE='\033[0;34m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
RED='\033[0;31m'
BOLD='\033[1m'
NC='\033[0m'

# ── Paths ──────────────────────────────────────────────────────
# Resolve our real location, following symlinks, so kacangje works whether it's
# run from a git clone, from $HOME/kacangje, or via a symlink on PATH (e.g. in
# /opt/homebrew/bin). An explicit KACANGJE_DIR env var always wins.
_src="${BASH_SOURCE[0]:-$0}"
while [[ -h "$_src" ]]; do
  _dir="$(cd -P "$(dirname "$_src")" && pwd)"
  _src="$(readlink "$_src")"
  [[ "$_src" != /* ]] && _src="$_dir/$_src"
done
_self_dir="$(cd -P "$(dirname "$_src")" && pwd)"
if [[ -z "${KACANGJE_DIR:-}" ]]; then
  if [[ -f "$_self_dir/web/server.py" ]]; then
    KACANGJE_DIR="$_self_dir"      # running from a checkout/install that has the files
  else
    KACANGJE_DIR="$HOME/kacangje"  # symlinked onto PATH; files live in the home install
  fi
fi
CONFIG_DIR="$HOME/.config/kacangje"
CONFIG_FILE="$CONFIG_DIR/kacangje.conf"

# ── Helpers ─────────────────────────────────────────────────────
info()  { echo -e "${BLUE}::${NC} $*"; }
ok()    { echo -e "${GREEN}✓${NC} $*"; }
warn()  { echo -e "${YELLOW}⚠${NC} $*" >&2; }
fail()  { echo -e "${RED}✗${NC} $*" >&2; exit 1; }

check_ollama() {
  if ! command -v ollama &>/dev/null; then
    warn "Ollama not found."
    return 1
  fi
  if ! ollama list &>/dev/null 2>&1; then
    warn "Ollama not running. Start: ollama serve"
    return 1
  fi
  return 0
}

get_best_model() {
  local model="malaysian-1.5b-reasoning"
  if ollama list 2>/dev/null | grep -q "malaysian-7b-dialect"; then
    model="malaysian-7b-dialect"
  elif ollama list 2>/dev/null | grep -q "malaysian-1.5b-reasoning"; then
    model="malaysian-1.5b-reasoning"
  elif ollama list 2>/dev/null | grep -q "qwen2.5:7b"; then
    model="qwen2.5:7b"
  fi
  echo "$model"
}

detect_ram() {
  if [[ "$(uname)" == "Darwin" ]]; then
    sysctl -n hw.memsize 2>/dev/null | awk '{print $1/1073741824}'
  else
    grep MemTotal /proc/meminfo 2>/dev/null | awk '{print $2/1048576}' || echo "4"
  fi
}

# ── Commands ────────────────────────────────────────────────────

cmd_list() {
  echo ""
  echo -e "${CYAN}╔══════════════════════════════════════════════╗${NC}"
  echo -e "${CYAN}║      🇲🇾  Malaysian AI — SME Edition        ║${NC}"
  echo -e "${CYAN}╚══════════════════════════════════════════════╝${NC}"
  echo ""
  if command -v ollama &>/dev/null && ollama list &>/dev/null 2>&1; then
    ollama list | grep -E "(malaysian|qwen2.5|llama)" | while read -r line; do
      name=$(echo "$line" | awk '{print $1}')
      size=$(echo "$line" | awk '{print $3}')
      case "$name" in
        malaysian-7b-dialect*)
          echo -e "  ${GREEN}${name}${NC} (${size}) — ✅ BEST: BM + Penang dialect, 21 tok/s";;
        malaysian-1.5b-reasoning*)
          echo -e "  ${GREEN}${name}${NC} (${size}) — ⚡ Fast: 87 tok/s, lightweight";;
        qwen2.5:7b*)
          echo -e "  ${GREEN}${name}${NC} (${size}) — Good BM, 21 tok/s";;
        *)
          echo -e "  ${GREEN}${name}${NC} (${size})";;
      esac
    done
  else
    echo -e "  ${YELLOW}No models found. Run: kacangje install${NC}"
  fi
  echo ""
  echo -e "  ${BLUE}Actions available:${NC}"
  for f in "$KACANGJE_DIR"/actions/*.py; do
    name=$(basename "$f" .py)
    echo -e "    ${GREEN}→${NC} $name"
  done
  echo ""
}

cmd_install() {
  echo ""
  echo -e "${CYAN}╔══════════════════════════════════════════════╗${NC}"
  echo -e "${CYAN}║      🇲🇾  kacangje install — SME Setup        ║${NC}"
  echo -e "${CYAN}╚══════════════════════════════════════════════╝${NC}"
  echo ""

  # 1. Install Ollama
  if ! command -v ollama &>/dev/null; then
    info "Installing Ollama..."
    if command -v brew &>/dev/null; then
      brew install ollama
    else
      warn "Install Homebrew first: https://brew.sh"
      warn "Then: brew install ollama"
      warn "Untuk Linux: curl -fsSL https://ollama.com/install.sh | sh"
      exit 1
    fi
  fi
  ok "Ollama installed"

  # 2. Start Ollama
  if ! ollama list &>/dev/null 2>&1; then
    info "Starting Ollama..."
    if [[ "$(uname)" == "Darwin" ]]; then
      brew services start ollama 2>/dev/null || true
    fi
    sleep 3
  fi
  ok "Ollama running"

  # 3. Auto-detect and pull best model
  local ram_gb
  ram_gb=$(detect_ram)
  info "Detected RAM: ${ram_gb}GB"

  local model="malaysian-1.5b-reasoning"
  if (( $(echo "$ram_gb >= 8" | bc -l 2>/dev/null || echo 0) )); then
    model="malaysian-7b-dialect"
  fi

  info "Pulling ${model}..."
  if ollama pull "$model" 2>/dev/null; then
    ok "Model $model sedia"
  else
    warn "Model $model tak jumpa di registry. Cuba import dari GGUF..."
    local gguf_path="$KACANGJE_DIR/models/Malaysian-Qwen2.5-7B-Dialect-Reasoning-GRPO-Q4_K_M.gguf"
    if [[ -f "$gguf_path" ]]; then
      cat > /tmp/Modelfile-kacangje << EOF
FROM $gguf_path
TEMPLATE """{{ if .System }}<|im_start|>system
{{ .System }}<|im_end|>
{{ end }}<|im_start|>user
{{ .Prompt }}<|im_end|>
<|im_start|>assistant
"""
PARAMETER temperature 0.2
PARAMETER top_p 0.9
PARAMETER repeat_penalty 1.1
PARAMETER num_predict 640
PARAMETER num_ctx 32768
PARAMETER stop "<|im_start|>"
EOF
      ollama create "$model" -f /tmp/Modelfile-kacangje
      ok "Model $model diimport dari GGUF"
    else
      warn "GGUF tak jumpa. Pull model lain: ollama pull qwen2.5:7b"
    fi
  fi

  # 4. Setup config directory
  mkdir -p "$CONFIG_DIR"
  if [[ ! -f "$CONFIG_FILE" ]]; then
    cp "$KACANGJE_DIR/config/kacangje.conf" "$CONFIG_FILE" 2>/dev/null || true
    ok "Config created at $CONFIG_FILE"
  fi

  # 5. Add to PATH (shell config)
  local shell_config=""
  if [[ -n "${ZSH_VERSION:-}" ]]; then
    shell_config="$HOME/.zshrc"
  elif [[ -n "${BASH_VERSION:-}" ]]; then
    shell_config="$HOME/.bashrc"
  fi
  if [[ -n "$shell_config" ]] && ! grep -q "kacangje" "$shell_config" 2>/dev/null; then
    echo "" >> "$shell_config"
    echo "# kacangje - Malaysian AI SME Assistant" >> "$shell_config"
    echo "export PATH=\"\$PATH:$KACANGJE_DIR\"" >> "$shell_config"
    echo "export KACANGJE_DIR=\"$KACANGJE_DIR\"" >> "$shell_config"
    ok "Added kacangje to PATH in $shell_config"
    ok "Run: source $shell_config"
  fi

  echo ""
  echo -e "${GREEN}╔══════════════════════════════════════════════╗${NC}"
  echo -e "${GREEN}║   🇲🇾  kacangje sedia!                        ║${NC}"
  echo -e "${GREEN}║                                            ║${NC}"
  echo -e "${GREEN}║  Try: kacangje web                           ║${NC}"
  echo -e "${GREEN}║       kacangje action gaji --workers 20      ║${NC}"
  echo -e "${GREEN}╚══════════════════════════════════════════════╝${NC}"
  echo ""
}

cmd_web() {
  # Start the web UI
  check_ollama || warn "Ollama tak jalan. Web UI tak boleh guna model."

  local port="${1:-8080}"
  info "Starting kacangje web UI on port $port..."
  echo ""

  if [[ ! -f "$KACANGJE_DIR/web/server.py" ]]; then
    fail "Web UI tak jumpa. Install dulu: kacangje install"
  fi

  cd "$KACANGJE_DIR"
  KACANGJE_DIR="$KACANGJE_DIR" KACANGJE_PORT="$port" python3 "$KACANGJE_DIR/web/server.py"
}

cmd_action() {
  # Run a pre-built action
  local action_name="${1:-}"
  shift 2>/dev/null || true

  if [[ -z "$action_name" ]]; then
    echo ""
    echo -e "${CYAN}Actions available:${NC}"
    for f in "$KACANGJE_DIR"/actions/*.py; do
      name=$(basename "$f" .py)
      echo -e "  ${GREEN}→${NC} kacangje action $name"
    done
    echo ""
    exit 0
  fi

  local action_script="$KACANGJE_DIR/actions/${action_name}.py"
  if [[ ! -f "$action_script" ]]; then
    fail "Action '$action_name' tak jumpa. Cuba: kacangje action"
  fi

  # Build JSON args from remaining CLI args
  local json_args="{}"
  if [[ $# -gt 0 ]]; then
    # Parse --key value or --key=value
    local args=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --*=*)
          key="${1%%=*}"; key="${key#--}"
          args+="$key=${1#*=}"$'\n'
          shift;;
        --*)
          local key="${1#--}"
          shift
          if [[ $# -gt 0 && ! "$1" =~ ^-- ]]; then
            args+="$key=$1"$'\n'
            shift
          else
            args+="$key=true"$'\n'
          fi;;
        *)
          shift;;
      esac
    done
    # Build JSON
    json_args="{"
    while IFS='=' read -r key value; do
      [[ -z "$key" ]] && continue
      # Determine type
      if [[ "$value" =~ ^[0-9]+(\.[0-9]+)?$ ]]; then
        json_args+="\"$key\": $value,"
      elif [[ "$value" == "true" || "$value" == "false" ]]; then
        json_args+="\"$key\": $value,"
      else
        json_args+="\"$key\": \"$value\","
      fi
    done <<< "$args"
    json_args="${json_args%,}}"
  fi

  info "Running action: ${action_name}"
  info "Args: $json_args"
  echo ""

  python3 "$action_script" "$json_args"
}

cmd_prompt() {
  # Agentic mode: prompt → AI interprets → does work
  local prompt="${*:-}"
  if [[ -z "$prompt" ]]; then
    # Interactive mode — rich REPL with slash commands & skills
    cd "$KACANGJE_DIR"
    KACANGJE_DIR="$KACANGJE_DIR" python3 "$KACANGJE_DIR/lib/repl.py"
    return
  fi

  check_ollama || exit 1
  local model
  model=$(get_best_model)

  info "Using ${model}..."
  echo ""

  # Build a system prompt that tells the AI to act as an agentic assistant
  local system_prompt="Anda kacangje — pembantu AI pejabat untuk SME Malaysia. Tepat, ringkas, tajam.
Tugas: bantu kerja pejabat harian (automasi, dokumen, invois, gaji/cukai, analisis data, emel/surat BM).

CARA JAWAB (ikut betul-betul):
- RINGKAS & TAJAM. Terus buat / terus jawab — jangan mukadimah, jangan ulang soalan, jangan ayat pengisi.
- SPESIFIK. Jawab apa yang diminta sahaja; jangan tambah yang tak diminta.
- Bahasa Malaysia (campur English bila perlu).
- JANGAN REKA nombor, kadar, tarikh, atau undang-undang. Tak pasti — kata tak pasti, cadang semak KWSP/PERKESO/LHDN.
- Berhenti bila dah siap."

  # Use ollama's chat API with system prompt
  local full_prompt="<|im_start|>system
${system_prompt}<|im_end|>
<|im_start|>user
${prompt}<|im_end|>
<|im_start|>assistant"

  ollama run "$model" <<< "$full_prompt"
}

cmd_templates() {
  local category="${1:-}"
  local tmpl_file="$KACANGJE_DIR/templates/sme-tasks.json"

  if [[ ! -f "$tmpl_file" ]]; then
    fail "Templates tak jumpa. Install dulu: kacangje install"
  fi

  if [[ -n "$category" ]]; then
    python3 -c "
import json
with open('$tmpl_file') as f:
    tmpls = json.load(f)
filtered = [t for t in tmpls if t.get('category') == '$category']
if not filtered:
    filtered = tmpls
for t in filtered:
    print(f\"  {t.get('icon', '📋')} {t['title']}\")
    print(f\"    {t.get('description', '')}\")
    print()
"
  else
    echo ""
    echo -e "${CYAN}📋 SME Templates Available:${NC}"
    echo ""

    # Group by category
    python3 -c "
import json
with open('$tmpl_file') as f:
    tmpls = json.load(f)
cats = {}
for t in tmpls:
    cat = t.get('category', 'other')
    cats.setdefault(cat, []).append(t)
for cat in cats:
    print(f'\\n  ${BOLD}{cat.upper()}{NC}')
    for t in cats[cat]:
        print(f\"    {t.get('icon', '📋')} {t['title']}\")
        print(f\"      {t.get('description', '')}\")
"
    echo ""
    echo -e "  ${BLUE}Guna:${NC} kacangje template <category>"
    echo -e "  ${BLUE}Atau:${NC} buka web UI di http://localhost:8080"
    echo ""
  fi
}

cmd_sme() {
  # SME dashboard: quick info about the setup
  echo ""
  echo -e "${CYAN}╔══════════════════════════════════════════════╗${NC}"
  echo -e "${CYAN}║    🇲🇾  kacangje SME Dashboard                ║${NC}"
  echo -e "${CYAN}╚══════════════════════════════════════════════╝${NC}"
  echo ""

  # Ollama status
  if check_ollama 2>/dev/null; then
    ok "Ollama: running"
    local model
    model=$(get_best_model)
    info "Model: $model"
    local ram_gb
    ram_gb=$(detect_ram)
    info "RAM: ${ram_gb}GB"
  else
    warn "Ollama: not running"
  fi

  # Actions count
  local action_count
  action_count=$(find "$KACANGJE_DIR/actions" -name "*.py" 2>/dev/null | wc -l | tr -d ' ')
  info "Actions: $action_count available (gaji, invoice, susun-fail, excel-analisis...)"

  # Templates
  local tmpl_count
  tmpl_count=$(python3 -c "import json; print(len(json.load(open('$KACANGJE_DIR/templates/sme-tasks.json'))))" 2>/dev/null || echo "0")
  info "Templates: $tmpl_count SME tasks"

  # Web UI
  info "Web UI: http://localhost:8080 (run: kacangje web)"

  echo ""
  echo -e "  ${BLUE}Quick start:${NC}"
  echo -e "    ${GREEN}→${NC} kacangje web          Buka web UI"
  echo -e "    ${GREEN}→${NC} kacangje prompt       Agentic mode (taip apa-aja)"
  echo -e "    ${GREEN}→${NC} kacangje action gaji  Kira gaji"
  echo -e "    ${GREEN}→${NC} kacangje templates    Lihat template"
  echo ""
}

# ── Main ────────────────────────────────────────────────────────

case "${1:-}" in
  list|ls)
    cmd_list
    ;;
  install|init|setup)
    cmd_install
    ;;
  web)
    cmd_web "${2:-8080}"
    ;;
  action|do)
    shift
    cmd_action "$@"
    ;;
  prompt|ask|chat)
    shift
    cmd_prompt "$@"
    ;;
  template|templates)
    shift
    cmd_templates "$@"
    ;;
  skill|skills)
    KACANGJE_DIR="$KACANGJE_DIR" python3 -c "
import sys; sys.path.insert(0, '$KACANGJE_DIR')
from lib.skills import list_skills
skills = list_skills()
if not skills:
    print('  Tiada skill dijumpai.')
else:
    print('')
    print('  🇲🇾  Skills tersedia (guna dalam: kacangje prompt → /<nama>):')
    print('')
    for s in skills:
        print(f\"    → {s['name']}: {s['description']}\")
    print('')
"
    ;;
  sme|dashboard|status)
    cmd_sme
    ;;
  --version|-v)
    echo "kacangje v${VERSION}"
    ;;
  help|--help|-h|"")
    echo ""
    echo -e "${CYAN}🇲🇾  kacangje — Malaysian AI SME Assistant${NC}"
    echo ""
    echo -e "  ${BLUE}Usage:${NC}"
    echo -e "    kacangje list         ${YELLOW}List models & actions${NC}"
    echo -e "    kacangje install      ${YELLOW}Install Ollama, model, dependencies${NC}"
    echo -e "    kacangje web          ${YELLOW}Start web UI (browser-based)${NC}"
    echo -e "    kacangje prompt       ${YELLOW}Agentic mode — just type what you need${NC}"
    echo -e "    kacangje action       ${YELLOW}Run pre-built office actions${NC}"
    echo -e "    kacangje templates    ${YELLOW}Browse SME task templates${NC}"
    echo -e "    kacangje skills       ${YELLOW}List skills (tulis-surat, emel-pelanggan...)${NC}"
    echo -e "    kacangje sme          ${YELLOW}SME dashboard / status${NC}"
    echo -e "    kacangje --version    ${YELLOW}Show version${NC}"
    echo ""
    echo -e "  ${BLUE}Examples:${NC}"
    echo -e "    kacangje web                    # Start web UI at port 8080"
    echo -e "    kacangje prompt \"Kira gaji 20 pekerja\""
    echo -e "    kacangje action gaji --workers 5 --gaji_pokok 2000"
    echo -e "    kacangje templates accounting   # Browse accounting templates"
    echo ""
    echo -e "  ${BLUE}Architecture:${NC}"
    echo -e "    Same agentic loop as OpenCode/Claude Code, but for office work."
    echo -e "    Prompt → AI interprets → executes action → returns result."
    echo -e "    100% offline. No API bills. No internet needed."
    echo ""
    ;;
  *)
    warn "Unknown command: $1"
    echo "Usage: kacangje <command>"
    echo "Try: kacangje help"
    exit 1
    ;;
esac
